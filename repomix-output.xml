          <div style={{ fontFamily:'Bebas Neue, sans-serif', fontSize:'2rem',
            color:'#ff3c3c', letterSpacing:2 }}>POLARTRONIC</div>
          <div style={{ color:'rgba(255,255,255,0.4)', fontSize:'0.85rem', marginTop:6 }}>
            Panel de Administración
