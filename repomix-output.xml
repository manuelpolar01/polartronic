                background: 'rgba(255,60,60,0.08)', border: '1px solid rgba(255,60,60,0.2)',
                color: '#ff3c3c', padding: '6px 14px', borderRadius: 6,
                cursor: 'pointer', fontSize: 12,
              }}>
                {deleting === idx ? '...' : '🗑 Borrar'}
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  )
}
