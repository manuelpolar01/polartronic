  email:    { it:'Email',                 en:'Email',                 es:'Email',                fr:'E-mail',                de:'E-Mail',                  pt:'E-mail'               },
  phone:    { it:'Telefono',              en:'Phone',                 es:'Teléfono',             fr:'Téléphone',             de:'Telefon',                 pt:'Telefone'             },
