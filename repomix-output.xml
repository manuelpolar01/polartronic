          letter-spacing: 1.2px;
          transition: color 0.2s;
          white-space: nowrap;
        }
        .nav-link:hover { color: ${primary}; }
      `}</style>

      <header style={{
        position: 'fixed', top: 0, left: 0, right: 0, width: '100%',
        zIndex: 1000,
        height: scrolled ? 64 : 80,
        padding: '0 5%',
