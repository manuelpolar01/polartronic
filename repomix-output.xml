                  </FieldGroup>
                )}
                <FieldGroup label="¿Campo requerido?">
                  <label style={{ display: 'flex', alignItems: 'center', gap: 10, cursor: 'pointer' }}>
                    <input type="checkbox" checked={!!fieldForm.required}
