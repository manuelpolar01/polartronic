                e.currentTarget.style.color = primary
                e.currentTarget.style.background = `rgba(255,60,60,0.08)`
              }}
              onMouseLeave={e => {
                e.currentTarget.style.color = 'rgba(255,255,255,0.85)'
                e.currentTarget.style.background = 'transparent'
              }}
            >
              {l.label}
            </a>
          ))}
        </div>
      )}
    </>
  )
}
