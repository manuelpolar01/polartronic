<file path="src/components/admin/tabs/LanguageTab.jsx">
/**
 * LanguageTab.jsx
 * ─────────────────────────────────────────────────────────────────────────
 * Admin panel tab for configuring the site language.
 *
 * Works in BOTH contexts:
 *  • Polartronic admin  →  data = { site, setSite }  (from useSiteData)
 *  • BarberBook Pro     →  data = { theme, setTheme } (from useTheme / Supabase)
 *
 * The component normalises both shapes internally so the same file
 * can be dropped into either panel without changes.
 *
 * When saved it:
 *  1. Persists brand.language to Firestore via saveSiteConfig (Polartronic)
 *     OR updates theme_config.language (BarberBook Pro) — pluggable via the
 *     optional `onSave` prop.
 *  2. Sets window.__SITE_LANGUAGE__ so the hook picks it up immediately
 *     without a full page reload.
 */

import { useState, useCallback } from 'react'
import toast from 'react-hot-toast'
import { SUPPORTED_LANGUAGES } from '../../../lib/uiStrings'

// ── Optional: Polartronic's saveSiteConfig
// If not available (BarberBook context) the onSave prop handles persistence.
let saveSiteConfig
try {
  saveSiteConfig = (await import('../../../lib/firebaseHelpers')).saveSiteConfig
} catch { /* not in Polartronic context */ }

// ─────────────────────────────────────────────────────────────────────────

export default function LanguageTab({
  /** Polartronic shape: { site, setSite }
   *  BarberBook shape:  { theme, setTheme }
   *  Both shapes accepted. */
  data = {},
  /** Optional override save handler (e.g. Supabase upsert for BarberBook) */
  onSave,
}) {
  // ── Normalise data shape ──────────────────────────────────────────────
  const isBB   = !!data.theme   // BarberBook Pro shape
  const source = isBB ? data.theme?.language : data.site?.brand?.language
  const setter = isBB ? data.setTheme        : data.setSite

  const [selected, setSelected] = useState(source ?? 'it')
  const [saving,   setSaving]   = useState(false)
  const [preview,  setPreview]  = useState(source ?? 'it')

  // ── Handlers ─────────────────────────────────────────────────────────
  const handleSelect = useCallback((code) => {
    setSelected(code)
  }, [])

  const handleSave = useCallback(async () => {
    setSaving(true)
    try {
      if (typeof onSave === 'function') {
        // Caller-supplied handler (BarberBook Pro, etc.)
        await onSave(selected)
      } else if (saveSiteConfig) {
        // Polartronic: persist into site/config.brand.language
        await saveSiteConfig({ brand: { language: selected } })
        setter?.(prev => ({
          ...prev,
          brand: { ...(prev.brand || {}), language: selected },
        }))
      }

      // Propagate to window so hook picks it up without reload
      if (typeof window !== 'undefined') {
        window.__SITE_LANGUAGE__ = selected
      }

      setPreview(selected)
      toast.success(`Lingua impostata: ${SUPPORTED_LANGUAGES.find(l => l.code === selected)?.label}`)
    } catch (err) {
      console.error('[LanguageTab]', err)
      toast.error('Errore durante il salvataggio')
    } finally {
      setSaving(false)
    }
  }, [selected, onSave, setter])

  // ── Derived ──────────────────────────────────────────────────────────
  const current  = SUPPORTED_LANGUAGES.find(l => l.code === selected)
  const hasChange = selected !== preview

  // ── Render ───────────────────────────────────────────────────────────
  return (
    <div>
      {/* ── Header ── */}
      <div style={{ marginBottom: 28 }}>
        <h2 style={{ fontSize: '1.5rem', fontWeight: 800, marginBottom: 6 }}>
          🌐 Lingua del Sito
        </h2>
        <p style={{ color: 'rgba(255,255,255,0.4)', fontSize: 14, lineHeight: 1.6 }}>
          Scegli la lingua predefinita per tutti i testi dell'interfaccia pubblica:
          navigazione, sezioni, form di contatto e flusso di prenotazione.
          I contenuti inseriti manualmente (titoli, descrizioni) non vengono tradotti automaticamente.
        </p>
      </div>

      {/* ── Language grid ── */}
      <div className="section-card">
        <h3 style={{
          fontSize: 12, fontWeight: 700, marginBottom: 18,
          color: 'rgba(255,255,255,0.4)',
          textTransform: 'uppercase', letterSpacing: 1.5,
        }}>
          Seleziona lingua
        </h3>

        <div style={{
          display: 'grid',
          gridTemplateColumns: 'repeat(auto-fill, minmax(160px, 1fr))',
          gap: 10,
        }}>
          {SUPPORTED_LANGUAGES.map(lang => {
            const isActive  = selected === lang.code
            const isSaved   = preview  === lang.code
            return (
              <button
                key={lang.code}
                onClick={() => handleSelect(lang.code)}
                style={{
                  display: 'flex',
                  alignItems: 'center',
                  gap: 12,
                  padding: '14px 18px',
                  borderRadius: 12,
                  border: isActive
                    ? '2px solid var(--primary)'
                    : '2px solid rgba(255,255,255,0.07)',
                  background: isActive
                    ? 'rgba(255,60,60,0.08)'
                    : 'rgba(255,255,255,0.02)',
                  cursor: 'pointer',
                  transition: 'all 0.18s',
                  textAlign: 'left',
                  position: 'relative',
                  overflow: 'hidden',
                }}
                onMouseEnter={e => {
                  if (!isActive) {
                    e.currentTarget.style.borderColor = 'rgba(255,255,255,0.2)'
                    e.currentTarget.style.background  = 'rgba(255,255,255,0.04)'
                  }
                }}
                onMouseLeave={e => {
                  if (!isActive) {
                    e.currentTarget.style.borderColor = 'rgba(255,255,255,0.07)'
                    e.currentTarget.style.background  = 'rgba(255,255,255,0.02)'
                  }
                }}
              >
                {/* Flag emoji */}
                <span style={{ fontSize: 24, lineHeight: 1, flexShrink: 0 }}>
                  {lang.flag}
                </span>

                {/* Label + code */}
                <div style={{ minWidth: 0 }}>
                  <div style={{
                    fontWeight: isActive ? 700 : 500,
                    fontSize: 14,
                    color: isActive ? 'white' : 'rgba(255,255,255,0.65)',
                    lineHeight: 1.2,
                  }}>
                    {lang.label}
                  </div>
                  <div style={{
                    fontSize: 10, fontWeight: 700,
                    textTransform: 'uppercase', letterSpacing: 1.2,
                    color: isActive ? 'var(--primary)' : 'rgba(255,255,255,0.25)',
                    marginTop: 2,
                  }}>
                    {lang.code}
                  </div>
                </div>

                {/* Active indicator */}
                {isActive && (
                  <div style={{
                    position: 'absolute', top: 8, right: 10,
                    width: 8, height: 8, borderRadius: '50%',
                    background: 'var(--primary)',
                    boxShadow: '0 0 8px var(--primary)',
                  }} />
                )}

                {/* Saved checkmark (different from active selection) */}
                {isSaved && selected !== preview && (
                  <div style={{
                    position: 'absolute', top: 8, right: 10,
                    fontSize: 10, color: 'rgba(255,255,255,0.3)',
                  }}>
                    ✓
                  </div>
                )}
              </button>
            )
          })}
        </div>
      </div>

      {/* ── Preview panel ── */}
      <div className="section-card" style={{ marginTop: 0 }}>
        <h3 style={{
          fontSize: 12, fontWeight: 700, marginBottom: 16,
          color: 'rgba(255,255,255,0.4)',
          textTransform: 'uppercase', letterSpacing: 1.5,
        }}>
          Anteprima stringhe — {current?.flag} {current?.label}
        </h3>

        <StringPreview lang={selected} />
      </div>

      {/* ── Info box ── */}
      <div style={{
        background: 'rgba(255,200,0,0.04)',
        border: '1px solid rgba(255,200,0,0.15)',
        borderRadius: 10, padding: '14px 18px',
        fontSize: 12, color: 'rgba(255,200,0,0.7)',
        lineHeight: 1.7, marginBottom: 20,
      }}>
        <strong>Come funziona:</strong>
        <ul style={{ margin: '6px 0 0', paddingLeft: 18, display: 'flex', flexDirection: 'column', gap: 3 }}>
          <li>Tutti i testi dell'UI (nav, bottoni, etichette, messaggi di sistema) vengono tradotti automaticamente.</li>
          <li>I contenuti personalizzati (headline hero, titoli sezioni, descrizioni servizi) restano come li hai scritti.</li>
          <li>Il flusso di prenotazione usa la stessa lingua qui configurata.</li>
          <li>La lingua è attiva immediatamente dopo il salvataggio, senza ricaricare la pagina.</li>
        </ul>
      </div>

      {/* ── Save button ── */}
      <div style={{ display: 'flex', alignItems: 'center', gap: 14 }}>
        <button
          className="save-btn"
          onClick={handleSave}
          disabled={saving || !hasChange}
          style={{ opacity: (!hasChange && !saving) ? 0.45 : 1 }}
        >
          {saving ? '💾 Salvataggio…' : `💾 SALVA — ${current?.flag} ${current?.label}`}
        </button>

        {!hasChange && preview && (
          <span style={{ fontSize: 12, color: 'rgba(255,255,255,0.3)' }}>
            ✓ Già salvato:{' '}
            {SUPPORTED_LANGUAGES.find(l => l.code === preview)?.flag}{' '}
            {SUPPORTED_LANGUAGES.find(l => l.code === preview)?.label}
          </span>
        )}
      </div>
    </div>
  )
}

// ─────────────────────────────────────────────────────────────────────────
// STRING PREVIEW
// Shows a sample of translated strings for the selected language
// ─────────────────────────────────────────────────────────────────────────

import { getStrings } from '../../../lib/uiStrings'

function StringPreview({ lang }) {
  const t = getStrings(lang)

  const rows = [
    { section: 'Navigazione',   samples: [t.nav.home, t.nav.services, t.nav.projects, t.nav.contact, t.nav.booking] },
    { section: 'Hero',          samples: [t.hero.badge, t.hero.exploreCta] },
    { section: 'Sezioni',       samples: [t.services.eyebrow, t.projects.eyebrow, t.testimonials.eyebrow] },
    { section: 'Contatto',      samples: [t.contact.eyebrow, t.contact.sendBtn, t.contact.privacy?.slice(0, 60) + '…'] },
    { section: 'Prenotazione',  samples: [t.booking.title, t.booking.selectService, t.booking.confirm, t.booking.confirmed] },
    { section: 'Calendario',    samples: [...(t.booking.weekdays ?? []), '|', ...(t.booking.months?.slice(0, 4) ?? [])] },
  ]

  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
      {rows.map(row => (
        <div key={row.section} style={{
          display: 'grid',
          gridTemplateColumns: '110px 1fr',
          gap: 10,
          alignItems: 'flex-start',
        }}>
          <div style={{
            fontSize: 10, fontWeight: 700, textTransform: 'uppercase',
            letterSpacing: 1.2, color: 'rgba(255,255,255,0.3)',
            paddingTop: 2,
          }}>
            {row.section}
          </div>
          <div style={{ display: 'flex', flexWrap: 'wrap', gap: 5 }}>
            {row.samples.filter(Boolean).map((s, i) => (
              s === '|'
                ? <span key={`sep-${i}`} style={{ color: 'rgba(255,255,255,0.1)', alignSelf: 'center' }}>·</span>
                : (
                  <span key={i} style={{
                    background: 'rgba(255,255,255,0.05)',
                    border: '1px solid rgba(255,255,255,0.08)',
                    borderRadius: 6,
                    padding: '3px 9px',
                    fontSize: 12,
                    color: 'rgba(255,255,255,0.65)',
                    whiteSpace: 'nowrap',
                  }}>
                    {s}
                  </span>
                )
            ))}
          </div>
        </div>
      ))}
    </div>
  )
}
