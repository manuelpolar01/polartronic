              <button onClick={() => handleDelete(t,idx)} disabled={deleting===idx}
                style={{ background:'rgba(255,60,60,0.08)', border:'1px solid rgba(255,60,60,0.2)',
                  color:'#ff3c3c', padding:'6px 12px', borderRadius:6, cursor:'pointer', fontSize:11 }}>
                {deleting===idx?'...':'🗑'}
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  )
}
