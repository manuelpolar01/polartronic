                  </FieldGroup>
                </div>
                {fieldForm.type === 'select' && (
                  <FieldGroup label="Opciones (separadas por coma)">
                    <input className="admin-input" value={fieldForm.options}
                      onChange={e => setFieldForm(p => ({ ...p, options: e.target.value }))}
