            </div>
          </div>

          <div className="section-card">
            <h3 style={{ fontSize: 13, fontWeight: 700, marginBottom: 16, color: 'rgba(255,255,255,0.5)', textTransform: 'uppercase', letterSpacing: 1 }}>
              Pantalla de Éxito (post-envío)
